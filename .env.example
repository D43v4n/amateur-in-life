# ─── BlueWatch · Variables de entorno ───────────────────────
# Copia este archivo como .env y rellena tus keys

# VirusTotal — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=tu_api_key_aqui

# Shodan — https://account.shodan.io/
SHODAN_API_KEY=tu_api_key_aqui

# AbuseIPDB — https://www.abuseipdb.com/api (opcional, gratis)
ABUSEIPDB_API_KEY=tu_api_key_aqui

# Puerto del servidor
PORT=3000
